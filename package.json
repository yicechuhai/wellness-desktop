{
  "name": "wellness-desktop",
  "version": "1.0.0",
  "description": "养生馆经营跟进系统 - 桌面版",
  "main": "main.js",
  "homepage": ".",
  "scripts": {
    "build": "vite build",
    "start": "concurrently \"node backend/server.cjs\" \"electron .\"",
    "dev": "vite build && node backend/server.cjs"
  },
  "build": {
    "appId": "com.wellness.desktop",
    "productName": "养生馆经营跟进系统",
    "asar": false,
    "directories": { "output": "dist" },
    "files": ["main.js", "preload.js", "backend/**/*", "frontend/**/*", "node_modules/**/*"],
    "win": { "target": "dir" },
    "mac": { "target": "dir" },
    "linux": { "target": "AppImage" }
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.4.1",
    "autoprefixer": "^10.4.21",
    "concurrently": "^9.0.0",
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3",
    "postcss": "^8.5.3",
    "tailwindcss": "^3.4.19",
    "tailwindcss-animate": "^1.0.7",
    "typescript": "^5.8.3",
    "vite": "^6.3.5"
  },
  "dependencies": {
    "better-sqlite3": "^12.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cors": "^2.8.5",
    "express": "^4.21.0",
    "lucide-react": "^0.510.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "react-router-dom": "^6.30.0",
    "tailwind-merge": "^3.3.0",
    "xlsx": "^0.18.5"
  }
}
